SERVER_PORT=8080
ADDON_KEY=stop-at-estimate
ADDON_NAME="Stop @ Estimate"
ADDON_DESCRIPTION="Stops timers and locks projects when time or budget estimates are reached."
ADDON_SIDEBAR_LABEL="Stop @ Estimate"
ADDON_BASE_URL=https://YOUR-HTTPS-URL

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/stop_at_estimate
SPRING_DATASOURCE_USERNAME=stop_at_estimate
SPRING_DATASOURCE_PASSWORD=stop_at_estimate

# Generate unique values per deploy. The app REJECTS the well-known example
# values shown in documentation and refuses to start if either variable is unset.
#   openssl rand -hex 32   # APP_ENCRYPTION_KEY_HEX  (>= 64 hex chars)
#   openssl rand -hex 32   # APP_ENCRYPTION_SALT_HEX (>= 64 hex chars, 256-bit)
APP_ENCRYPTION_KEY_HEX=REPLACE_WITH_OUTPUT_OF_openssl_rand_hex_32
APP_ENCRYPTION_SALT_HEX=REPLACE_WITH_OUTPUT_OF_openssl_rand_hex_32

CLOCKIFY_CUTOFF_INTERVAL_MS=60000
